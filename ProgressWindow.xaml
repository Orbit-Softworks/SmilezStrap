<Window x:Class="SmilezStrap.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmilezStrap" Height="200" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True">
    
    <Window.Resources>
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation Storyboard.TargetName="GlowBorder" 
                           Storyboard.TargetProperty="Opacity"
                           From="0.3" To="0.6" Duration="0:0:1" 
                           AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
        
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="Transparent" Padding="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF0000" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        
        <Border x:Name="GlowBorder" Background="#000000" CornerRadius="12" 
                BorderThickness="1" BorderBrush="#FF0000" Opacity="0.6">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
            
            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock x:Name="TitleIcon" Text="🎮" Foreground="#FF0000" FontSize="20" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TitleText" Text="Launching Roblox" Foreground="White" FontSize="18" 
                             FontWeight="SemiBold"/>
                </StackPanel>

                <TextBlock Grid.Row="1" x:Name="StatusText" Text="Initializing..." 
                         Foreground="White" FontSize="14" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" x:Name="DetailText" Text="" 
                         Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,15"/>

                <Grid Grid.Row="3" Margin="0,0,0,8">
                    <Border Background="#121212" Height="8" CornerRadius="4">
                        <Border x:Name="ProgressBarFill" Background="#FF0000" Height="8" 
                              HorizontalAlignment="Left" Width="0" CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF0000" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </Grid>

                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" x:Name="PercentText" Text="0%" 
                             Foreground="#FF0000" FontSize="16" FontWeight="Bold"/>
                    
                    <TextBlock Grid.Column="1" x:Name="StageText" Text="Preparing..." 
                             Foreground="#888888" FontSize="11" HorizontalAlignment="Center" 
                             VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="2" x:Name="TimeEstimateText" Text="" 
                             Foreground="#888888" FontSize="11"/>
                </Grid>

                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="32"
                          Style="{StaticResource SecondaryButton}"
                          Click="CancelButton_Click" Visibility="Visible"/>
                    <Button x:Name="CloseButton" Content="Close" Width="80" Height="32"
                          Style="{StaticResource PrimaryButton}"
                          Click="CloseButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
