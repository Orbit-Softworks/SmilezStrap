<Window x:Class="SmilezStrap.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmilezStrap" Height="450" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True">
    
    <Window.Resources>
        <!-- Clean, modern animations -->
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation Storyboard.TargetName="GlowBorder" 
                           Storyboard.TargetProperty="Opacity"
                           From="0.4" To="0.7" Duration="0:0:1.5" 
                           AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
        
        <Storyboard x:Key="WindowOpenAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(Window.RenderTransform).(ScaleTransform.ScaleX)" 
                           From="0.3" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(Window.RenderTransform).(ScaleTransform.ScaleY)" 
                           From="0.3" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                    <Setter Property="BorderBrush" Value="#FF0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>

    <Border Background="Transparent" Padding="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF0000" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>
        
        <Border x:Name="GlowBorder" Background="#000000" CornerRadius="0" 
                BorderThickness="1" BorderBrush="#FF0000">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
            
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title with Icon -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock x:Name="TitleIcon" Text="🎮" Foreground="#FF0000" FontSize="24" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TitleText" Text="Launching Roblox" Foreground="White" FontSize="20" 
                             FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Main Status -->
                <TextBlock Grid.Row="1" x:Name="StatusText" Text="Initializing..." 
                         Foreground="White" FontSize="14" Margin="0,0,0,10"/>

                <!-- Detailed Status -->
                <TextBlock Grid.Row="2" x:Name="DetailText" Text="" 
                         Foreground="#E0E0E0" FontSize="11" Margin="0,0,0,20"/>

                <!-- Progress Bar -->
                <Grid Grid.Row="3" Margin="0,0,0,10">
                    <Border Background="#111111" Height="4" CornerRadius="0">
                        <Border x:Name="ProgressBarFill" Background="#FF0000" Height="4" 
                              HorizontalAlignment="Left" Width="0" CornerRadius="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF0000" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </Grid>

                <!-- Percentage and Stage -->
                <Grid Grid.Row="4" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" x:Name="PercentText" Text="0%" 
                             Foreground="#FF0000" FontSize="18" FontWeight="Bold"/>
                    
                    <TextBlock Grid.Column="1" x:Name="StageText" Text="Preparing..." 
                             Foreground="#909090" FontSize="11" HorizontalAlignment="Center" 
                             VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="2" x:Name="TimeEstimateText" Text="" 
                             Foreground="#909090" FontSize="11"/>
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="35"
                          Style="{StaticResource SecondaryButton}"
                          Click="CancelButton_Click" Visibility="Visible" Margin="0,0,10,0"/>
                    <Button x:Name="CloseButton" Content="Close" Width="80" Height="35"
                          Style="{StaticResource PrimaryButton}"
                          Click="CloseButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
