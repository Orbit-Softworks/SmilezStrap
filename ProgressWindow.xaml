<Window x:Class="SmilezStrap.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmilezStrap" Height="200" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True">
    
    <Window.Resources>
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation Storyboard.TargetName="GlowBorder" 
                           Storyboard.TargetProperty="Opacity"
                           From="0.3" To="0.6" Duration="0:0:1" 
                           AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="Transparent" Padding="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF4444" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        
        <Border x:Name="GlowBorder" Background="#0F0F0F" CornerRadius="12" 
                BorderThickness="1" BorderBrush="#FF4444" Opacity="0.6">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
            
            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock x:Name="TitleIcon" Text="🎮" Foreground="#FF4444" FontSize="20" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TitleText" Text="Launching Roblox" Foreground="White" FontSize="18" 
                             FontWeight="SemiBold"/>
                </StackPanel>

                <TextBlock Grid.Row="1" x:Name="StatusText" Text="Initializing..." 
                         Foreground="White" FontSize="14" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" x:Name="DetailText" Text="" 
                         Foreground="#999" FontSize="11" Margin="0,0,0,15"/>

                <Grid Grid.Row="3" Margin="0,0,0,8">
                    <Border Background="#252525" Height="8" CornerRadius="4">
                        <Border x:Name="ProgressBarFill" Background="#FF4444" Height="8" 
                              HorizontalAlignment="Left" Width="0" CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF4444" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </Grid>

                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" x:Name="PercentText" Text="0%" 
                             Foreground="#FF4444" FontSize="16" FontWeight="Bold"/>
                    
                    <TextBlock Grid.Column="1" x:Name="StageText" Text="Preparing..." 
                             Foreground="#666" FontSize="11" HorizontalAlignment="Center" 
                             VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="2" x:Name="TimeEstimateText" Text="" 
                             Foreground="#666" FontSize="11"/>
                </Grid>

                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="32"
                          Style="{StaticResource SecondaryButton}"
                          Click="CancelButton_Click" Visibility="Visible"/>
                    <Button x:Name="CloseButton" Content="Close" Width="80" Height="32"
                          Style="{StaticResource PrimaryButton}"
                          Click="CloseButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
