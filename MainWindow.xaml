<Window x:Class="SmilezStrap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmilezStrap" Height="650" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
   
    <Window.Resources>
        <!-- AMOLED Black & Red Theme -->
        <Color x:Key="AccentColor">#FF0000</Color>
        <Color x:Key="AccentGlow">#8B0000</Color>
        <Color x:Key="BackgroundDark">#000000</Color>
        <Color x:Key="BackgroundMedium">#0A0A0A</Color>
        <Color x:Key="BackgroundLight">#121212</Color>
        <Color x:Key="BorderColor">#1E1E1E</Color>
        <Color x:Key="TextPrimary">#FFFFFF</Color>
        <Color x:Key="TextSecondary">#CCCCCC</Color>
        <Color x:Key="TextMuted">#888888</Color>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FF0000"/>
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#121212" Height="4" CornerRadius="2" Margin="0,8,0,0"/>
                            <Thumb x:Name="Thumb" Grid.Row="0" Width="16" Height="16" Margin="0,2,0,0"
                                   Background="White" BorderBrush="#FF0000" BorderThickness="2"
                                   Cursor="Hand">
                                <Thumb.Template>
                                    <ControlTemplate>
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="18" Height="18" CornerRadius="4" 
                                    Background="#121212" BorderBrush="#333333" BorderThickness="1">
                                <Border x:Name="CheckMark" Background="#FF0000" CornerRadius="3" 
                                        Margin="2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0" 
                                            VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#121212"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF0000"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Border Background="Transparent" Padding="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF0000" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        
        <Border Background="#000000" CornerRadius="12" BorderThickness="1" BorderBrush="#1E1E1E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0A0A0A" CornerRadius="12,0,0,12" 
                        BorderThickness="0,0,1,0" BorderBrush="#1E1E1E">
                    <Grid>
                        <Grid Height="70" VerticalAlignment="Top" Margin="0,20,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🎮" FontSize="20" Foreground="#FF0000" Margin="0,0,8,0"/>
                                <TextBlock Text="SmilezStrap" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,100,0,0">
                            <Button Style="{StaticResource MenuButton}" x:Name="HomeButton" Click="HomeButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="16" Margin="0,0,12,0"/>
                                    <TextBlock Text="Home"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Style="{StaticResource MenuButton}" x:Name="SettingsButton" Click="SettingsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0"/>
                                    <TextBlock Text="Settings"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Style="{StaticResource MenuButton}" x:Name="AboutButton" Click="About_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,12,0"/>
                                    <TextBlock Text="About"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Bottom" Margin="16,0,16,20">
                            <Button x:Name="CheckUpdatesButton" 
                                    Content="🔄 Check for Updates" 
                                    Height="40" 
                                    Style="{StaticResource SecondaryButton}" 
                                    Click="CheckUpdatesButton_Click" 
                                    Margin="0,0,0,12"/>
                            
                            <Border Background="#121212" CornerRadius="6" Padding="10">
                                <StackPanel>
                                    <TextBlock x:Name="VersionText" 
                                               Text="v1.0.70" 
                                               Foreground="#CCCCCC" 
                                               FontSize="11" 
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="ready" 
                                               Foreground="#888888" 
                                               FontSize="10" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid Height="50" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                            <Button Content="─" Width="40" Height="40" Background="Transparent" 
                                    BorderThickness="0" Foreground="#CCCCCC" FontSize="16" 
                                    Click="MinimizeButton_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="6" Margin="2">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#121212"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✕" Width="40" Height="40" Background="Transparent" 
                                    BorderThickness="0" Foreground="#CCCCCC" FontSize="16" 
                                    Click="CloseButton_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="6" Margin="2">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF0000"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="HomeView" Margin="40,60,40,40" Visibility="Visible">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="HomeViewTransform" Y="0"/>
                        </StackPanel.RenderTransform>
                        
                        <TextBlock Text="Welcome back!" FontSize="28" FontWeight="Light" 
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="What would you like to launch today?" 
                                   FontSize="14" Foreground="#CCCCCC" Margin="0,0,0,40"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                                <Button Style="{StaticResource PrimaryButton}" Height="140" 
                                        Background="Transparent" Click="LaunchRoblox_Click">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🎮" FontSize="48" Foreground="#FF0000" 
                                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Roblox" FontSize="16" FontWeight="SemiBold" 
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Launch Player" FontSize="12" 
                                                   Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                            
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                                <Button Style="{StaticResource PrimaryButton}" Height="140" 
                                        Background="Transparent" Click="LaunchStudio_Click">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🛠️" FontSize="48" Foreground="#FF0000" 
                                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Studio" FontSize="16" FontWeight="SemiBold" 
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Create &amp; Edit" FontSize="12" 
                                                   Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>

                        <Grid Margin="0,25,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="📊 Status" FontSize="12" FontWeight="SemiBold" 
                                               Foreground="#FF0000" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="RobloxStatusText" Text="Roblox: Ready" 
                                               FontSize="11" Foreground="#CCCCCC" Margin="0,2,0,2"/>
                                    <TextBlock x:Name="VersionStatusText" Text="Version: Latest" 
                                               FontSize="11" Foreground="#888888"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="⚡ Quick Actions" FontSize="12" FontWeight="SemiBold" 
                                               Foreground="#FF0000" Margin="0,0,0,8"/>
                                    <Button Content="Clear Cache" Style="{StaticResource SecondaryButton}" 
                                            Height="28" FontSize="11" Margin="0,0,0,6"/>
                                    <Button Content="Repair Installation" Style="{StaticResource SecondaryButton}" 
                                            Height="28" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <ScrollViewer x:Name="SettingsView" Margin="40,60,40,30" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.RenderTransform>
                            <TranslateTransform x:Name="SettingsViewTransform" Y="0"/>
                        </ScrollViewer.RenderTransform>

                        <StackPanel MaxWidth="800">
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Settings" Style="{StaticResource SectionHeader}" FontSize="24"/>
                                <TextBlock Text="Customize your Roblox experience" 
                                           FontSize="13" Foreground="#888888"/>
                            </StackPanel>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Read-Only Mode" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="White"/>
                                        <TextBlock Text="Prevent Roblox from overriding your settings" 
                                                   Foreground="#888888" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ReadOnlyCheckBox" Grid.Column="1" 
                                              VerticalAlignment="Center" IsChecked="False"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="Graphics &amp; Performance" Style="{StaticResource SectionHeader}"/>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Graphics Quality" FontSize="13" 
                                                           FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="Adjust visual fidelity" 
                                                           Foreground="#888888" FontSize="11"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#121212" 
                                                    CornerRadius="4" Padding="6,3">
                                                <TextBlock x:Name="GraphicsQualityValue" 
                                                           Text="Level 1" Foreground="#FF0000" 
                                                           FontSize="12" FontWeight="SemiBold" 
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <Slider x:Name="GraphicsQualitySlider" 
                                                Minimum="0" Maximum="9" Value="1" 
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                ValueChanged="GraphicsQualitySlider_ValueChanged"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="FPS Limit" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock Text="Maximum framerate" Foreground="#888888" 
                                                   FontSize="11" Margin="0,0,0,12"/>
                                        <TextBox x:Name="FpsLimitTextBox" Text="9999"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="User Interface" Style="{StaticResource SectionHeader}"/>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="UI Transparency" FontSize="13" 
                                                           FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="Menu opacity" Foreground="#888888" FontSize="11"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#121212" 
                                                    CornerRadius="4" Padding="6,3">
                                                <TextBlock x:Name="TransparencyValue" 
                                                           Text="1.0" Foreground="#FF0000" 
                                                           FontSize="12" FontWeight="SemiBold" 
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <Slider x:Name="TransparencySlider" Minimum="0" Maximum="1" 
                                                Value="1" TickFrequency="0.1" 
                                                ValueChanged="TransparencySlider_ValueChanged"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Reduced Motion" FontSize="13" 
                                                       FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="Disable menu animations" 
                                                       Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ReducedMotionCheckBox" Grid.Column="1" 
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <TextBlock Text="Input &amp; Controls" Style="{StaticResource SectionHeader}"/>
                            
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Mouse Sensitivity" FontSize="13" 
                                                   FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock Text="Camera movement speed" Foreground="#888888" 
                                                   FontSize="11" Margin="0,0,0,12"/>
                                        <TextBox x:Name="MouseSensitivityTextBox" Text="0.360000014"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="VR Mode" FontSize="13" 
                                                       FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="Enable VR support" 
                                                       Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="VREnabledCheckBox" Grid.Column="1" 
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Button x:Name="SaveAllSettingsButton" 
                                    Content="💾 Save All Settings" 
                                    Height="48" 
                                    Style="{StaticResource PrimaryButton}" 
                                    Click="SaveAllSettingsButton_Click" 
                                    FontSize="15"
                                    Margin="0,10,0,0"/>

                            <TextBlock Text="Changes will be applied on next launch"
                                       Foreground="#666666" FontSize="10" Margin="0,12,0,0" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="AboutView" Margin="40,60,40,40" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.RenderTransform>
                            <TranslateTransform x:Name="AboutViewTransform" Y="0"/>
                        </ScrollViewer.RenderTransform>
                        
                        <StackPanel>
                            <TextBlock Text="About SmilezStrap" Style="{StaticResource SectionHeader}" FontSize="24"/>
                            
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock x:Name="AboutContentText" TextWrapping="Wrap" 
                                               Foreground="#CCCCCC" FontSize="12" LineHeight="20"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Community &amp; Support" FontSize="15" 
                                               FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                                    <Button Content="🌐 GitHub Repository" Height="35" Margin="0,0,0,8" 
                                            Style="{StaticResource SecondaryButton}" Click="VisitGitHub_Click"/>
                                    <Button Content="💬 Discord Server" Height="35" 
                                            Style="{StaticResource SecondaryButton}" Click="Discord_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="DiscordPopup" Grid.ColumnSpan="2" Background="#CC000000" Visibility="Collapsed">
                        <Border Background="#0A0A0A" CornerRadius="12" BorderThickness="1" BorderBrush="#FF0000" 
                                Width="400" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF0000" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel Margin="30" VerticalAlignment="Center">
                                    <TextBlock Text="⚠️ External Link" FontSize="18" FontWeight="SemiBold" 
                                               Foreground="#FF0000" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="You are about to be redirected to our Discord server." 
                                               FontSize="13" Foreground="#CCCCCC" TextWrapping="Wrap" 
                                               HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="Are you sure you want to continue?" FontSize="13" 
                                               Foreground="#888888" TextWrapping="Wrap" HorizontalAlignment="Center" 
                                               Margin="0,0,0,20"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Yes, Continue" Height="40" 
                                                Style="{StaticResource PrimaryButton}" Click="DiscordPopupYes_Click"/>
                                        <Button Grid.Column="2" Content="Cancel" Height="40" 
                                                Style="{StaticResource SecondaryButton}" Click="DiscordPopupNo_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
